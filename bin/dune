(rule
 (targets metadata.ml)
 (action
  (write-file
   metadata.ml
   "let version = \"v%{version:ggh}\"let commit = \"%{env:GGHCOMMITSHA=unknown}\"")))

(executable
 (public_name ggh)
 (name main)
 (libraries ggh dolog str))
