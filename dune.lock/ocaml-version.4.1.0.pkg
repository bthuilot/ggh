(version 4.1.0)

(build
 (all_platforms
  ((action
    (progn
     (when %{pkg-self:dev} (run dune subst))
     (run dune build -p %{pkg-self:name} -j %{jobs} @install))))))

(depends
 (all_platforms
  (dune ocaml)))

(source
 (fetch
  (url
   https://github.com/ocurrent/ocaml-version/releases/download/v4.1.0/ocaml-version-4.1.0.tbz)
  (checksum md5=b20bae45ebd270f4ed85efabddc2e7ec)))
